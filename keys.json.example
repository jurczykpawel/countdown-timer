{
    "_comment": "Remote bgImage URLs are DENIED by default. A key must opt in via allow_remote_bg=true; setting bg_domains restricts to listed hosts (exact or subdomain match).",

    "tk_master_CHANGE_ME": {
        "name": "Master (Pawel)",
        "limit": 0,
        "active": true,
        "allow_remote_bg": true
    },
    "tk_free_EXAMPLE": {
        "name": "Free tier example",
        "limit": 1000,
        "active": true,
        "max_width": 640,
        "max_height": 200,
        "max_seconds": 30
    },
    "tk_pro_EXAMPLE": {
        "name": "Pro tier with allowlisted bg domains",
        "limit": 100000,
        "active": true,
        "max_width": 1200,
        "max_height": 400,
        "max_seconds": 120,
        "allow_remote_bg": true,
        "bg_domains": ["images.example.com", "cdn.mycompany.com"]
    }
}
